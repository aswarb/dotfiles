(deflisten focusedProgram
  :initial ""
  "scripts/sway_getFocusedProgram.sh"
)

(deflisten allWorkspaces
  :initial "[1]"
  "scripts/sway_getWorkspaces.sh"
)

(deflisten activeWorkspaces
  :initial "[]"
  "scripts/sway_getActiveWorkspace.sh"
)

(deflisten focusedWorkspace
  :initial "1"
  "scripts/sway_getFocusedWorkspace.sh"
)

(defvar roman_numerals '{"1":"I","2":"II","3":"III","4":"IV","5":"V","6":"VI","7":"VII","8":"VIII","9":"IX","10":"X"}')
