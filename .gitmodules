[submodule ".config/alacritty/themes"]
	path = .config/alacritty/themes
	url = https://github.com/alacritty/alacritty-theme.git
[submodule ".config/rofi/rofi-themes-collection"]
	path = .config/rofi/rofi-themes-collection
	url = git@github.com:newmanls/rofi-themes-collection.git
[submodule ".themes/perigee"]
	path = .themes/perigee
	url = https://github.com/aswarb/perigee-gtk-theme.git
	branch = dist
